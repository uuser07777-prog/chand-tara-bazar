*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial,Helvetica,sans-serif;
}

body{
background:#0f172a;
color:#fff;
line-height:1.6;
}

header{
display:flex;
justify-content:space-between;
align-items:center;
padding:18px 8%;
background:#111827;
position:sticky;
top:0;
z-index:1000;
box-shadow:0 3px 10px rgba(0,0,0,.3);
}

.logo{
font-size:26px;
font-weight:bold;
color:#38bdf8;
}

nav{
display:flex;
gap:20px;
flex-wrap:wrap;
}

nav a{
color:#fff;
text-decoration:none;
font-weight:600;
transition:.3s;
}

nav a:hover{
color:#38bdf8;
}

.hero{
padding:90px 8%;
text-align:center;
background:linear-gradient(135deg,#1e293b,#0f172a);
}

.hero h1{
font-size:48px;
margin-bottom:20px;
}

.hero p{
font-size:18px;
max-width:700px;
margin:auto;
opacity:.9;
}

.btn{
display:inline-block;
margin-top:30px;
padding:14px 28px;
background:#38bdf8;
color:#fff;
text-decoration:none;
border-radius:8px;
font-weight:bold;
transition:.3s;
}

.btn:hover{
transform:translateY(-2px);
background:#0ea5e9;
}

.cards{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(260px,1fr));
gap:25px;
padding:60px 8%;
}

.card{
background:#1e293b;
padding:25px;
border-radius:15px;
transition:.3s;
}

.card:hover{
transform:translateY(-8px);
}

.card h2{
margin-bottom:15px;
color:#38bdf8;
}

footer{
text-align:center;
padding:30px;
background:#111827;
margin-top:50px;
font-size:15px;
color:#cbd5e1;
}

form{
max-width:600px;
margin:40px auto;
padding:25px;
background:#1e293b;
border-radius:12px;
}

input,
textarea{
width:100%;
padding:14px;
margin:12px 0;
border:none;
border-radius:8px;
background:#334155;
color:#fff;
}

button{
padding:14px 28px;
border:none;
background:#38bdf8;
color:#fff;
border-radius:8px;
cursor:pointer;
font-size:16px;
}

button:hover{
background:#0ea5e9;
}

@media(max-width:768px){

header{
flex-direction:column;
gap:15px;
}

.hero{
padding:70px 20px;
}

.hero h1{
font-size:34px;
}

.hero p{
font-size:16px;
}

nav{
justify-content:center;
}

.cards{
padding:40px 20px;
}

}
